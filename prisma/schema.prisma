// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id             Int       @id @default(autoincrement())
  name           String
  reports        reports[]
  profilepicture String?

  password                    String
  isAdmin                     Boolean                       @default(false)
  roleId                      Int?
  role                        Role?                         @relation(fields: [roleId], references: [id])
  rentalcarfundReportsDetails rentalcarfundReportsDetails[]
  email                       String?
  phoneNumber                 String?
  notfications                notifications[]
  nationalId                  String?
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  emailLogs                   EmailLog[]
  investmentSectors           UserInvestmentSector[]
}

// قطاع استثمار (تأجير، توظيف، ضيافة، …)
model InvestmentSector {
  id        Int                    @id @default(autoincrement())
  key       String                 @unique // مثلاً: cars | recruitment | hospitality
  nameAr    String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  investors UserInvestmentSector[]
}

// ربط مستثمر ↔ قطاعات (many-to-many)
model UserInvestmentSector {
  userId    Int
  sectorId  Int
  user      user             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sector    InvestmentSector @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@id([userId, sectorId])
  @@index([sectorId])
}

// OTP للتحقق عند تسجيل الدخول (يُخزَّن في الـ API لأسباب أمنية)
model OtpVerification {
  id          Int      @id @default(autoincrement())
  nationalId  String
  phoneNumber String
  otp         String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([nationalId, phoneNumber])
}

// أدوار الأدمن — أعلى رتبة اسمها admin وتستطيع كل شيء
model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique // مثلاً: admin, محرر_محتوى, دعم
  users       user[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// صلاحية صفحة معينة لرتبة — يمكن التحكم في العرض والتعديل
model RolePermission {
  id        Int      @id @default(autoincrement())
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  pageKey   String // مفتاح الصفحة: funds, contact, quick-contact, investment-register, extract-reports, review, roles
  canView   Boolean  @default(true)
  canEdit   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, pageKey])
}

model reports {
  id          Int      @id @default(autoincrement())
  type        String
  isPublished Boolean  @default(false)
  userId      Int
  isApproved  Boolean  @default(false)
  fileName    String?
  releaseDate DateTime
  user        user     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  linkUrl     String
}

model rentalcarfundReportsDetails {
  id Int @id @default(autoincrement())

  revenues        Int?
  expenses        Int?
  profit          Int?
  withdrawen      Int?
  afterwithdrawen Int?
  previousyear    Int?
  netprofit       Int?
  investorId      Int
  investor        user     @relation(fields: [investorId], references: [id])
  CARSCount       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// model withdrawen{

// }
model notifications {
  id       Int     @id @default(autoincrement())
  type     String
  title    String?
  message  String? @db.Text
  isGlobal Boolean @default(false)

  userId Int

  user      user     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  linkUrl   String
}

// سجل رسائل البريد الإلكتروني المرسلة من لوحة الأدمن للمستثمرين
model EmailLog {
  id            Int      @id @default(autoincrement())
  subject       String
  body          String   @db.Text
  sentTo        String   @db.Text // JSON array of email addresses
  recipientId   Int? // null = bulk (all)
  recipient     user?    @relation(fields: [recipientId], references: [id])
  sentByAdminId Int?
  status        String   @default("sent") // sent | failed
  errorMsg      String?  @db.Text
  createdAt     DateTime @default(now())
}

// model fundsDetails {

// id Int @id @default(autoincrement())

// }

model rentalcarfund {
  id                Int      @id @default(autoincrement())
  daysRental        String?
  availableServices String?
  avaiableCars      String?
  branches          Int
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model recruitmentFund {
  id             Int      @id @default(autoincrement())
  branches       Int
  contractsCount String?
  homemaidsCound String?
  musanadRating  String
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model hospitalityFund {
  id             Int      @id @default(autoincrement())
  branches       Int
  contractsCount String?
  homemaidsCound String?
  musanadRating  String
  facilities     String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// محتوى قسم «تواصل معنا» (العنوان، أوقات العمل، هاتف، بريد) — يُعرض في ContactSection
model ContactUs {
  id                 Int      @id @default(autoincrement())
  sectionTitle       String? // تواصل معنا
  addressLine1       String?
  addressLine2       String?
  workingDays        String?
  workingHours       String?
  phone              String?
  email              String?
  formRecipientEmail String? // البريد المستلم لرسائل النموذج
  mailSenderEmail    String? // بريد الإرسال (SMTP)
  mailSenderPassword String? // كلمة مرور بريد الإرسال
  emailLogoUrl       String? // شعار البريد (مفتاح أو رابط من DigitalOcean)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// رسائل الزوار من نموذج «تواصل معنا» (الاسم، البريد، الجوال، الرسالة)
model ContactFormSubmission {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String?
  message   String?  @db.Text
  createdAt DateTime @default(now())
}

// محتوى بلوك «سجل اهتمامك» في صفحة الاستثمار (كيفية البدء + النص + روابط الصناديق)
model InvestmentRegisterBlock {
  id                 Int      @id @default(autoincrement())
  howToTitle         String?
  howToSubtitle      String?
  howToImageUrl      String?
  step1Title         String?
  step1Description   String?
  step2Title         String?
  step2Description   String?
  step3Title         String?
  step3Description   String?
  step4Title         String?
  step4Description   String?
  registerHeading    String? // امتداد عريق بخبرة تجاوزت الثلاثة عقود
  registerSubheading String? // الصناديق الاستثمارية
  registerFormTitle  String? // سجل اهتمامك واستثمر معنا
  formRecipientEmail String? // البريد المستلم لطلبات سجل الاهتمام
  mailSenderEmail    String? // بريد الإرسال (SMTP)
  mailSenderPassword String? // كلمة مرور بريد الإرسال
  emailLogoUrl       String? // شعار روائس للاستثمار في البريد (مفتاح أو رابط من DigitalOcean)
  fund1Title         String?
  fund1Href          String?
  fund2Title         String?
  fund2Href          String?
  fund3Title         String?
  fund3Href          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// طلبات «سجل اهتمامك» من صفحة الاستثمار (الاسم، البريد، الجوال، الصندوق، المبلغ)
model InvestmentInterestSubmission {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  fund      String? // hospitality | cars | recruitment
  amount    String? // 50-100 | 100-500 | 500+
  createdAt DateTime @default(now())
}

// أرقام التواصل السريع في صفحة المستثمر (واتساب)
model QuickContactSettings {
  id               Int      @id @default(autoincrement())
  legalPhone       String? // الإدارة القانونية
  managementPhone  String? // الإدارة العليا
  suggestionsPhone String? // للاقتراحات والمساعدة
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
